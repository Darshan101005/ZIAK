{{ 'section-ziak-reviews.css' | asset_url | stylesheet_tag }}

<div class="ziak-reviews" id="ziak-reviews-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">

  <!-- Decorative header: line — title — line -->
  <div class="ziak-reviews__header">
    <span class="ziak-reviews__line"></span>
    <span class="ziak-reviews__title">{{ section.settings.section_title | default: 'WHAT OUR CUSTOMERS SAY' }}</span>
    <span class="ziak-reviews__line"></span>
  </div>

  <!-- 3-column review cards -->
  <div class="ziak-reviews__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'review' -%}
        <div class="ziak-reviews__card" id="ziak-review-{{ forloop.index }}" {{ block.shopify_attributes }}>

          <span class="ziak-reviews__quote">&ldquo;</span>

          <p class="ziak-reviews__text">{{ block.settings.review_text }}</p>

          <div class="ziak-reviews__stars" aria-label="{{ block.settings.star_count }} stars">
            {%- for i in (1..5) -%}
              <span class="ziak-reviews__star{% if i <= block.settings.star_count %} ziak-reviews__star--on{% endif %}">★</span>
            {%- endfor -%}
          </div>

          <p class="ziak-reviews__name">— {{ block.settings.reviewer_name }}</p>

        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

</div>

{% schema %}
{
  "name": "ZIAK Customer Reviews",
  "tag": "section",
  "class": "ziak-reviews-section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "default": "WHAT OUR CUSTOMERS SAY",
      "label": "Section title"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Customer Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "default": "The quality is exceptional. You can feel the craftsmanship in every detail.",
          "label": "Review text"
        },
        {
          "type": "range",
          "id": "star_count",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Star rating"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "default": "Daniel R.",
          "label": "Reviewer name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZIAK Customer Reviews",
      "blocks": [
        { "type": "review", "settings": { "review_text": "The quality is exceptional. You can feel the craftsmanship in every detail.", "star_count": 5, "reviewer_name": "Daniel R." } },
        { "type": "review", "settings": { "review_text": "Stylish, comfortable, and built to last. ZIAK is my go-to for everything.", "star_count": 5, "reviewer_name": "Olivia M." } },
        { "type": "review", "settings": { "review_text": "Timeless designs and outstanding service. Highly recommend!", "star_count": 5, "reviewer_name": "James T." } }
      ]
    }
  ]
}
{% endschema %}
