{{ 'section-ziak-top-categories.css' | asset_url | stylesheet_tag }}

<div class="ziak-topcats" id="ziak-top-categories">

  <!-- Section Heading -->
  <h2 class="ziak-topcats__title" id="ziak-topcats-heading">
    {{ section.settings.section_title | default: 'Top Categories' }}
  </h2>

  <div class="ziak-topcats__grid">

    <!-- LEFT: Large Featured Card -->
    <div class="ziak-topcats__card ziak-topcats__card--featured">
      {%- if section.settings.featured_image != blank -%}
        {{
          section.settings.featured_image
          | image_url: width: 1200
          | image_tag:
            sizes: '50vw',
            widths: '600, 900, 1200',
            loading: 'lazy',
            class: 'ziak-topcats__img'
        }}
      {%- else -%}
        {{ 'collection-apparel-1' | placeholder_svg_tag: 'ziak-topcats__img ziak-topcats__img--placeholder' }}
      {%- endif -%}

      <div class="ziak-topcats__overlay">
        <p class="ziak-topcats__label">{{ section.settings.featured_label | default: 'Bestsellers' }}</p>
        <p class="ziak-topcats__sub">{{ section.settings.featured_sub | default: 'Shop our most popular items' }}</p>
        <a href="{{ section.settings.featured_link }}" class="ziak-topcats__btn" id="ziak-topcats-featured-btn">
          {{ section.settings.featured_btn_text | default: 'Shop now' }}
        </a>
      </div>
    </div>

    <!-- RIGHT: 2×3 small cards grid -->
    <div class="ziak-topcats__small-grid">

      {%- for i in (1..6) -%}
        {%- assign img_key     = 'cat_' | append: i | append: '_image' -%}
        {%- assign label_key   = 'cat_' | append: i | append: '_label' -%}
        {%- assign btn_key     = 'cat_' | append: i | append: '_btn' -%}
        {%- assign link_key    = 'cat_' | append: i | append: '_link' -%}

        {%- assign cat_img   = section.settings[img_key] -%}
        {%- assign cat_label = section.settings[label_key] -%}
        {%- assign cat_btn   = section.settings[btn_key] | default: 'Shop now' -%}
        {%- assign cat_link  = section.settings[link_key] -%}

        <div class="ziak-topcats__card ziak-topcats__card--small" id="ziak-topcats-card-{{ i }}">
          {%- if cat_img != blank -%}
            {{
              cat_img
              | image_url: width: 600
              | image_tag:
                sizes: '25vw',
                widths: '300, 450, 600',
                loading: 'lazy',
                class: 'ziak-topcats__img'
            }}
          {%- else -%}
            {{ 'collection-apparel-2' | placeholder_svg_tag: 'ziak-topcats__img ziak-topcats__img--placeholder' }}
          {%- endif -%}

          <div class="ziak-topcats__overlay ziak-topcats__overlay--small">
            <p class="ziak-topcats__label ziak-topcats__label--small">{{ cat_label }}</p>
            <a href="{{ cat_link }}" class="ziak-topcats__btn ziak-topcats__btn--small" id="ziak-topcats-btn-{{ i }}">
              {{ cat_btn }}
            </a>
          </div>
        </div>
      {%- endfor -%}

    </div>
  </div>
</div>

