{{ 'section-ziak-footer.css' | asset_url | stylesheet_tag }}

<footer class="ziak-footer" id="ziak-footer">

  <!-- ── Main 4-column layout ── -->
  <div class="ziak-footer__grid">

    <!-- Col 1: Shop -->
    <div class="ziak-footer__col">
      <h3 class="ziak-footer__col-heading">Shop</h3>
      <ul class="ziak-footer__links">
        {%- for i in (1..10) -%}
          {%- assign label_key = 'shop_link_' | append: i | append: '_label' -%}
          {%- assign url_key   = 'shop_link_' | append: i | append: '_url' -%}
          {%- if section.settings[label_key] != blank -%}
            <li><a href="{{ section.settings[url_key] | default: '#' }}" class="ziak-footer__link">{{ section.settings[label_key] }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <!-- Col 2: About -->
    <div class="ziak-footer__col">
      <h3 class="ziak-footer__col-heading">About</h3>
      <ul class="ziak-footer__links">
        {%- for i in (1..6) -%}
          {%- assign label_key = 'about_link_' | append: i | append: '_label' -%}
          {%- assign url_key   = 'about_link_' | append: i | append: '_url' -%}
          {%- if section.settings[label_key] != blank -%}
            <li><a href="{{ section.settings[url_key] | default: '#' }}" class="ziak-footer__link">{{ section.settings[label_key] }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <!-- Col 3: Support -->
    <div class="ziak-footer__col">
      <h3 class="ziak-footer__col-heading">Support</h3>
      <ul class="ziak-footer__links">
        {%- for i in (1..7) -%}
          {%- assign label_key = 'support_link_' | append: i | append: '_label' -%}
          {%- assign url_key   = 'support_link_' | append: i | append: '_url' -%}
          {%- if section.settings[label_key] != blank -%}
            <li><a href="{{ section.settings[url_key] | default: '#' }}" class="ziak-footer__link">{{ section.settings[label_key] }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    <!-- Col 4: Email + Socials -->
    <div class="ziak-footer__col ziak-footer__col--right">

      <!-- Email signup -->
      <p class="ziak-footer__email-label" id="ziak-footer-email-label">{{ section.settings.email_heading }}</p>
      <form class="ziak-footer__email-form" id="ziak-footer-email-form" action="/contact#contact_form" method="post" accept-charset="UTF-8">
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="ziak-footer__email-row">
          <input
            id="ziak-footer-email"
            class="ziak-footer__email-input"
            type="email"
            name="contact[email]"
            placeholder="email@example.com"
            autocomplete="email"
            required
          >
          <button type="submit" class="ziak-footer__email-btn" id="ziak-footer-email-btn">
            {{ section.settings.email_btn_label }}
          </button>
        </div>
      </form>

      <!-- Social icons -->
      <div class="ziak-footer__socials" id="ziak-footer-socials">
        {%- if section.settings.social_instagram != blank -%}
          <a href="{{ section.settings.social_instagram }}" class="ziak-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram" id="ziak-footer-instagram">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_facebook != blank -%}
          <a href="{{ section.settings.social_facebook }}" class="ziak-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook" id="ziak-footer-facebook">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_twitter != blank -%}
          <a href="{{ section.settings.social_twitter }}" class="ziak-footer__social-link" target="_blank" rel="noopener" aria-label="X (Twitter)" id="ziak-footer-twitter">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4 4l16 16M20 4L4 20" stroke-width="2.2" stroke-linecap="round"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_pinterest != blank -%}
          <a href="{{ section.settings.social_pinterest }}" class="ziak-footer__social-link" target="_blank" rel="noopener" aria-label="Pinterest" id="ziak-footer-pinterest">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.77 1.22-5.14 1.22-5.14s-.31-.62-.31-1.54c0-1.45.84-2.53 1.88-2.53.89 0 1.32.67 1.32 1.47 0 .9-.57 2.24-.87 3.48-.25 1.04.52 1.88 1.54 1.88 1.85 0 3.1-2.38 3.1-5.2 0-2.15-1.46-3.65-3.56-3.65-2.42 0-3.84 1.81-3.84 3.69 0 .73.28 1.51.63 1.94a.25.25 0 0 1 .06.24l-.24.96c-.04.15-.13.18-.29.11-1.05-.49-1.71-2.02-1.71-3.25 0-2.65 1.92-5.08 5.54-5.08 2.91 0 5.17 2.07 5.17 4.84 0 2.89-1.82 5.21-4.34 5.21-.85 0-1.64-.44-1.91-.96l-.52 1.95c-.19.72-.69 1.62-1.03 2.17.78.24 1.6.37 2.46.37 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_youtube != blank -%}
          <a href="{{ section.settings.social_youtube }}" class="ziak-footer__social-link" target="_blank" rel="noopener" aria-label="YouTube" id="ziak-footer-youtube">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white" stroke="none"/></svg>
          </a>
        {%- endif -%}
      </div>

      <!-- Country selector -->
      <div class="ziak-footer__country">
        <select class="ziak-footer__country-select" id="ziak-footer-country" aria-label="Select country/currency">
          <option selected>{{ section.settings.country_label }}</option>
        </select>
      </div>

    </div>
  </div>

  <!-- ── Bottom bar ── -->
  <div class="ziak-footer__bottom">
    <p class="ziak-footer__copy">{{ section.settings.copyright_text }}</p>
  </div>

</footer>

